<aside class="space-y-6">
    <!-- Community Stats -->
    <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-5">
        <h3 class="font-display font-semibold text-sm uppercase tracking-wider text-slate-300 mb-4">Community</h3>
        <div class="space-y-3">
            <div class="flex items-center justify-between">
                <span class="text-sm text-slate-400 flex items-center gap-2"><i data-lucide="users" class="w-4 h-4"></i> Members</span>
                <span class="text-sm font-semibold text-slate-200"><%= typeof stats !== 'undefined' ? helpers.formatNumber(stats.users) : '0' %></span>
            </div>
            <div class="flex items-center justify-between">
                <span class="text-sm text-slate-400 flex items-center gap-2"><i data-lucide="tent" class="w-4 h-4"></i> Spots</span>
                <span class="text-sm font-semibold text-slate-200"><%= typeof stats !== 'undefined' ? helpers.formatNumber(stats.campsites) : '0' %></span>
            </div>
            <div class="flex items-center justify-between">
                <span class="text-sm text-slate-400 flex items-center gap-2"><i data-lucide="map" class="w-4 h-4"></i> Routes</span>
                <span class="text-sm font-semibold text-slate-200"><%= typeof stats !== 'undefined' ? helpers.formatNumber(stats.routes) : '0' %></span>
            </div>
            <div class="flex items-center justify-between">
                <span class="text-sm text-slate-400 flex items-center gap-2"><i data-lucide="wrench" class="w-4 h-4"></i> Builds</span>
                <span class="text-sm font-semibold text-slate-200"><%= typeof stats !== 'undefined' ? helpers.formatNumber(stats.builds) : '0' %></span>
            </div>
            <div class="flex items-center justify-between">
                <span class="text-sm text-slate-400 flex items-center gap-2"><i data-lucide="messages-square" class="w-4 h-4"></i> Discussions</span>
                <span class="text-sm font-semibold text-slate-200"><%= typeof stats !== 'undefined' ? helpers.formatNumber(stats.posts) : '0' %></span>
            </div>
        </div>
    </div>

    <!-- Recent Activity -->
    <% if (typeof recentPosts !== 'undefined' && recentPosts.length > 0) { %>
    <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-5">
        <h3 class="font-display font-semibold text-sm uppercase tracking-wider text-slate-300 mb-4">Recent Discussions</h3>
        <div class="space-y-3">
            <% recentPosts.forEach(post => { %>
            <a href="/forum/<%= post.category %>/<%= post.slug %>" class="block group">
                <p class="text-sm text-slate-200 group-hover:text-amber-400 transition-colors line-clamp-1"><%= post.title %></p>
                <p class="text-xs text-slate-500 mt-0.5">by <%= post.username %> &middot; <%= helpers.formatDate(post.created_at, 'relative') %></p>
            </a>
            <% }) %>
        </div>
    </div>
    <% } %>

    <!-- Join CTA (for non-logged-in users) -->
    <% if (!isAuthenticated) { %>
    <div class="bg-gradient-to-br from-forest-900/50 to-slate-800/50 border border-forest-800 rounded-xl p-5 text-center">
        <i data-lucide="tent" class="w-8 h-8 text-forest-400 mx-auto mb-2"></i>
        <h3 class="font-display font-semibold text-slate-200 mb-1">Join the Community</h3>
        <p class="text-sm text-slate-400 mb-3">Share spots, routes, and connect with fellow travellers.</p>
        <a href="/auth/register" class="inline-block bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold text-sm px-4 py-2 rounded-lg transition-colors">Sign Up Free</a>
    </div>
    <% } %>
</aside>
