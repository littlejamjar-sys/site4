<header class="bg-slate-950 border-b border-slate-800 sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4">
        <div class="flex items-center justify-between h-16">
            <!-- Logo -->
            <a href="/" class="flex items-center gap-2 text-xl font-display font-bold text-amber-400 hover:text-amber-300 transition-colors">
                <i data-lucide="compass" class="w-7 h-7"></i>
                <span class="hidden sm:inline"><%= locals.siteName || 'The Overland Post' %></span>
            </a>

            <!-- Desktop Nav -->
            <nav class="hidden md:flex items-center gap-1">
                <a href="/articles" class="px-3 py-2 rounded-lg text-sm font-medium transition-colors <%= currentPath.startsWith('/articles') ? 'text-amber-400 bg-slate-800' : 'text-slate-300 hover:text-white hover:bg-slate-800' %>">
                    <i data-lucide="book-open" class="w-4 h-4 inline-block mr-1"></i>Magazine
                </a>
                <a href="/forum" class="px-3 py-2 rounded-lg text-sm font-medium transition-colors <%= currentPath.startsWith('/forum') ? 'text-amber-400 bg-slate-800' : 'text-slate-300 hover:text-white hover:bg-slate-800' %>">
                    <i data-lucide="message-square" class="w-4 h-4 inline-block mr-1"></i>Forum
                </a>
                <a href="/campsites" class="px-3 py-2 rounded-lg text-sm font-medium transition-colors <%= currentPath.startsWith('/campsites') ? 'text-amber-400 bg-slate-800' : 'text-slate-300 hover:text-white hover:bg-slate-800' %>">
                    <i data-lucide="map-pin" class="w-4 h-4 inline-block mr-1"></i>Spots
                </a>
                <a href="/routes" class="px-3 py-2 rounded-lg text-sm font-medium transition-colors <%= currentPath.startsWith('/routes') ? 'text-amber-400 bg-slate-800' : 'text-slate-300 hover:text-white hover:bg-slate-800' %>">
                    <i data-lucide="route" class="w-4 h-4 inline-block mr-1"></i>Routes
                </a>
                <a href="/builds" class="px-3 py-2 rounded-lg text-sm font-medium transition-colors <%= currentPath.startsWith('/builds') ? 'text-amber-400 bg-slate-800' : 'text-slate-300 hover:text-white hover:bg-slate-800' %>">
                    <i data-lucide="wrench" class="w-4 h-4 inline-block mr-1"></i>Builds
                </a>
            </nav>

            <!-- Right side -->
            <div class="flex items-center gap-2">
                <!-- Search -->
                <form action="/search" method="GET" class="hidden lg:flex items-center">
                    <div class="relative">
                        <input type="text" name="q" placeholder="Search..."
                            class="bg-slate-800 border border-slate-700 rounded-lg pl-9 pr-3 py-1.5 text-sm text-slate-200 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent w-48 focus:w-64 transition-all"
                            value="<%= typeof query !== 'undefined' ? query : '' %>">
                        <i data-lucide="search" class="w-4 h-4 text-slate-500 absolute left-3 top-1/2 -translate-y-1/2"></i>
                    </div>
                </form>

                <% if (isAuthenticated) { %>
                    <!-- Notifications -->
                    <a href="/api/notifications" class="relative p-2 text-slate-400 hover:text-white transition-colors" id="notifications-link"
                       onclick="event.preventDefault(); document.getElementById('notifications-dropdown').classList.toggle('hidden');">
                        <i data-lucide="bell" class="w-5 h-5"></i>
                        <span id="notification-count" class="absolute -top-0.5 -right-0.5 bg-amber-500 text-slate-900 text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center <%= unreadNotifications > 0 ? '' : 'hidden' %>">
                            <%= unreadNotifications > 99 ? '99+' : unreadNotifications %>
                        </span>
                    </a>

                    <!-- Notifications dropdown -->
                    <div id="notifications-dropdown" class="hidden absolute right-4 top-14 w-80 bg-slate-800 border border-slate-700 rounded-lg shadow-xl z-50 max-h-96 overflow-y-auto">
                        <div class="p-3 border-b border-slate-700 flex items-center justify-between">
                            <h3 class="font-semibold text-sm">Notifications</h3>
                            <button onclick="markAllRead()" class="text-xs text-amber-400 hover:text-amber-300">Mark all read</button>
                        </div>
                        <div id="notifications-list" class="divide-y divide-slate-700">
                            <p class="p-4 text-sm text-slate-400 text-center">Loading...</p>
                        </div>
                    </div>

                    <!-- User menu -->
                    <div class="relative">
                        <button onclick="document.getElementById('user-menu').classList.toggle('hidden')" class="flex items-center gap-2 p-1.5 rounded-lg hover:bg-slate-800 transition-colors">
                            <% if (currentUser.avatar_path) { %>
                                <img src="<%= currentUser.avatar_path %>" alt="" class="w-7 h-7 rounded-full object-cover">
                            <% } else { %>
                                <div class="w-7 h-7 rounded-full bg-forest-700 flex items-center justify-center text-sm font-bold text-forest-100">
                                    <%= currentUser.username.charAt(0).toUpperCase() %>
                                </div>
                            <% } %>
                            <i data-lucide="chevron-down" class="w-3.5 h-3.5 text-slate-400 hidden sm:block"></i>
                        </button>
                        <div id="user-menu" class="hidden absolute right-0 top-12 w-56 bg-slate-800 border border-slate-700 rounded-lg shadow-xl z-50">
                            <div class="p-3 border-b border-slate-700">
                                <p class="font-semibold text-sm"><%= currentUser.display_name || currentUser.username %></p>
                                <p class="text-xs text-slate-400">@<%= currentUser.username %></p>
                            </div>
                            <div class="py-1">
                                <a href="/auth/profile" class="flex items-center gap-2 px-3 py-2 text-sm text-slate-300 hover:bg-slate-700 hover:text-white">
                                    <i data-lucide="user" class="w-4 h-4"></i> Profile
                                </a>
                                <a href="/builds?mine=1" class="flex items-center gap-2 px-3 py-2 text-sm text-slate-300 hover:bg-slate-700 hover:text-white">
                                    <i data-lucide="wrench" class="w-4 h-4"></i> My Builds
                                </a>
                                <% if (currentUser.role === 'admin') { %>
                                <a href="/admin" class="flex items-center gap-2 px-3 py-2 text-sm text-slate-300 hover:bg-slate-700 hover:text-white">
                                    <i data-lucide="shield" class="w-4 h-4"></i> Admin
                                </a>
                                <% } %>
                            </div>
                            <div class="border-t border-slate-700 py-1">
                                <a href="/auth/logout" class="flex items-center gap-2 px-3 py-2 text-sm text-red-400 hover:bg-slate-700 hover:text-red-300">
                                    <i data-lucide="log-out" class="w-4 h-4"></i> Log out
                                </a>
                            </div>
                        </div>
                    </div>
                <% } else { %>
                    <a href="/auth/login" class="text-sm text-slate-300 hover:text-white transition-colors px-3 py-1.5">Log in</a>
                    <a href="/auth/register" class="text-sm bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold px-4 py-1.5 rounded-lg transition-colors">Join</a>
                <% } %>

                <!-- Mobile menu button -->
                <button id="mobile-menu-btn" class="md:hidden p-2 text-slate-400 hover:text-white">
                    <i data-lucide="menu" class="w-5 h-5"></i>
                </button>
            </div>
        </div>

        <!-- Mobile menu -->
        <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-slate-800 mt-2 pt-3">
            <form action="/search" method="GET" class="mb-3 lg:hidden">
                <div class="relative">
                    <input type="text" name="q" placeholder="Search..."
                        class="w-full bg-slate-800 border border-slate-700 rounded-lg pl-9 pr-3 py-2 text-sm text-slate-200 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-amber-500"
                        value="<%= typeof query !== 'undefined' ? query : '' %>">
                    <i data-lucide="search" class="w-4 h-4 text-slate-500 absolute left-3 top-1/2 -translate-y-1/2"></i>
                </div>
            </form>
            <div class="flex flex-col gap-1">
                <a href="/articles" class="px-3 py-2 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-slate-800 flex items-center gap-2">
                    <i data-lucide="book-open" class="w-4 h-4"></i> Magazine
                </a>
                <a href="/forum" class="px-3 py-2 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-slate-800 flex items-center gap-2">
                    <i data-lucide="message-square" class="w-4 h-4"></i> Forum
                </a>
                <a href="/campsites" class="px-3 py-2 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-slate-800 flex items-center gap-2">
                    <i data-lucide="map-pin" class="w-4 h-4"></i> Spots
                </a>
                <a href="/routes" class="px-3 py-2 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-slate-800 flex items-center gap-2">
                    <i data-lucide="route" class="w-4 h-4"></i> Routes
                </a>
                <a href="/builds" class="px-3 py-2 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-slate-800 flex items-center gap-2">
                    <i data-lucide="wrench" class="w-4 h-4"></i> Builds
                </a>
            </div>
        </div>
    </div>
</header>