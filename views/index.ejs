<%- include('layouts/main') %>

<!-- Hero Section -->
<section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-forest-950/50 via-slate-900 to-slate-900"></div>
    <div class="relative max-w-7xl mx-auto px-4 py-20 md:py-28 text-center">
        <h1 class="text-4xl md:text-6xl font-display font-bold text-slate-100 mb-4">
            Life is better <span class="text-amber-400">off-grid</span>
        </h1>
        <p class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto mb-8">
            A community for vanlifers, overlanders, and motorhome travellers. Discover wild camping spots, share travel routes, and document your build.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
            <% if (!isAuthenticated) { %>
            <a href="/auth/register" class="bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold px-8 py-3 rounded-lg transition-colors text-lg">Join the Community</a>
            <% } %>
            <a href="/campsites" class="bg-slate-800 hover:bg-slate-700 text-slate-200 font-semibold px-8 py-3 rounded-lg transition-colors border border-slate-700 flex items-center gap-2">
                <i data-lucide="map" class="w-5 h-5"></i> Explore the Map
            </a>
        </div>
    </div>
</section>

<div class="max-w-7xl mx-auto px-4 py-12 space-y-16">

    <!-- Featured Articles -->
    <% if (featuredArticles.length > 0) { %>
    <section>
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-display font-bold text-slate-100 flex items-center gap-2">
                <i data-lucide="newspaper" class="w-6 h-6 text-amber-400"></i> From the Magazine
            </h2>
            <a href="/articles" class="text-sm text-amber-400 hover:text-amber-300 flex items-center gap-1">View all <i data-lucide="arrow-right" class="w-4 h-4"></i></a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% featuredArticles.forEach(article => { %>
            <%- include('partials/article-card', { article }) %>
            <% }) %>
        </div>
    </section>
    <% } %>

    <!-- Map + Forum row -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Map Widget -->
        <div class="lg:col-span-2">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-2xl font-display font-bold text-slate-100 flex items-center gap-2">
                    <i data-lucide="tent" class="w-6 h-6 text-amber-400"></i> Latest Spots
                </h2>
                <a href="/campsites" class="text-sm text-amber-400 hover:text-amber-300 flex items-center gap-1">Full map <i data-lucide="arrow-right" class="w-4 h-4"></i></a>
            </div>
            <div id="home-map" class="w-full h-80 rounded-xl border border-slate-700 overflow-hidden"></div>
            <script>
                document.addEventListener('DOMContentLoaded', function() {
                    if (typeof initMap === 'function') {
                        const campsites = <%- JSON.stringify(latestCampsites.map(c => ({ id: c.id, name: c.name, lat: c.latitude, lng: c.longitude, type: c.type }))) %>;
                        initMap('home-map', { campsites, zoom: 5, center: [42, 2] });
                    }
                });
            </script>
        </div>

        <!-- Recent Forum Activity -->
        <div>
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-xl font-display font-bold text-slate-100 flex items-center gap-2">
                    <i data-lucide="messages-square" class="w-5 h-5 text-amber-400"></i> Discussions
                </h2>
                <a href="/forum" class="text-sm text-amber-400 hover:text-amber-300 flex items-center gap-1">All <i data-lucide="arrow-right" class="w-4 h-4"></i></a>
            </div>
            <div class="space-y-3">
                <% recentPosts.forEach(post => { %>
                <a href="/forum/<%= post.category %>/<%= post.slug %>" class="block bg-slate-800/50 border border-slate-700 rounded-lg p-4 hover:border-slate-600 transition-colors group">
                    <h3 class="text-sm font-semibold text-slate-200 group-hover:text-amber-400 transition-colors line-clamp-2"><%= post.title %></h3>
                    <div class="flex items-center gap-2 mt-2 text-xs text-slate-500">
                        <span>@<%= post.username %></span>
                        <span>&middot;</span>
                        <span><%= helpers.formatDate(post.created_at, 'relative') %></span>
                        <span>&middot;</span>
                        <span><%= post.reply_count %> replies</span>
                    </div>
                </a>
                <% }) %>
                <% if (recentPosts.length === 0) { %>
                <p class="text-sm text-slate-500 text-center py-8">No discussions yet. <a href="/forum/new" class="text-amber-400 hover:text-amber-300">Start one!</a></p>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Latest Builds -->
    <% if (latestBuilds.length > 0) { %>
    <section>
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-display font-bold text-slate-100 flex items-center gap-2">
                <i data-lucide="wrench" class="w-6 h-6 text-amber-400"></i> Build Logs
            </h2>
            <a href="/builds" class="text-sm text-amber-400 hover:text-amber-300 flex items-center gap-1">View all <i data-lucide="arrow-right" class="w-4 h-4"></i></a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% latestBuilds.forEach(build => { %>
            <%- include('partials/build-card', { build }) %>
            <% }) %>
        </div>
    </section>
    <% } %>

    <!-- Community Stats Bar -->
    <section class="bg-slate-800/30 border border-slate-700 rounded-xl p-8">
        <div class="grid grid-cols-2 md:grid-cols-5 gap-6 text-center">
            <div>
                <p class="text-3xl font-display font-bold text-amber-400"><%= helpers.formatNumber(stats.users) %></p>
                <p class="text-sm text-slate-400">Members</p>
            </div>
            <div>
                <p class="text-3xl font-display font-bold text-amber-400"><%= helpers.formatNumber(stats.campsites) %></p>
                <p class="text-sm text-slate-400">Spots</p>
            </div>
            <div>
                <p class="text-3xl font-display font-bold text-amber-400"><%= helpers.formatNumber(stats.routes) %></p>
                <p class="text-sm text-slate-400">Routes</p>
            </div>
            <div>
                <p class="text-3xl font-display font-bold text-amber-400"><%= helpers.formatNumber(stats.builds) %></p>
                <p class="text-sm text-slate-400">Builds</p>
            </div>
            <div class="col-span-2 md:col-span-1">
                <p class="text-3xl font-display font-bold text-amber-400"><%= helpers.formatNumber(stats.posts) %></p>
                <p class="text-sm text-slate-400">Discussions</p>
            </div>
        </div>
    </section>
</div>

<%- include('layouts/end') %>
