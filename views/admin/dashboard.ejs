<%- include('../layouts/main') %>

<div class="max-w-7xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-display font-bold text-slate-100 mb-8">Admin Dashboard</h1>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 mb-10">
        <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-forest-900/50 flex items-center justify-center"><i data-lucide="users" class="w-5 h-5 text-forest-400"></i></div>
                <div>
                    <p class="text-2xl font-display font-bold text-slate-100"><%= stats.users %></p>
                    <p class="text-xs text-slate-500">Users</p>
                </div>
            </div>
        </div>
        <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-amber-900/50 flex items-center justify-center"><i data-lucide="book-open" class="w-5 h-5 text-amber-400"></i></div>
                <div>
                    <p class="text-2xl font-display font-bold text-slate-100"><%= stats.publishedArticles %></p>
                    <p class="text-xs text-slate-500">Articles</p>
                </div>
            </div>
        </div>
        <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-blue-900/50 flex items-center justify-center"><i data-lucide="message-square" class="w-5 h-5 text-blue-400"></i></div>
                <div>
                    <p class="text-2xl font-display font-bold text-slate-100"><%= stats.forumPosts %></p>
                    <p class="text-xs text-slate-500">Forum Posts</p>
                </div>
            </div>
        </div>
        <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-red-900/50 flex items-center justify-center"><i data-lucide="map-pin" class="w-5 h-5 text-red-400"></i></div>
                <div>
                    <p class="text-2xl font-display font-bold text-slate-100"><%= stats.approvedCampsites %></p>
                    <p class="text-xs text-slate-500">Campsites</p>
                </div>
            </div>
        </div>
        <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-purple-900/50 flex items-center justify-center"><i data-lucide="wrench" class="w-5 h-5 text-purple-400"></i></div>
                <div>
                    <p class="text-2xl font-display font-bold text-slate-100"><%= stats.builds %></p>
                    <p class="text-xs text-slate-500">Builds</p>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Pending Campsites -->
        <div>
            <h2 class="text-lg font-display font-semibold text-slate-200 mb-4 flex items-center gap-2">
                <i data-lucide="alert-circle" class="w-5 h-5 text-amber-400"></i>
                Pending Campsites (<%= stats.pendingCampsites %>)
            </h2>
            <% if (pendingCampsites.length > 0) { %>
            <div class="space-y-3">
                <% pendingCampsites.forEach(c => { %>
                <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-4 flex items-center justify-between">
                    <div>
                        <p class="font-semibold text-slate-200"><%= c.name %></p>
                        <p class="text-xs text-slate-500"><%= c.country || 'Unknown' %> &middot; by @<%= c.username %> &middot; <%= helpers.formatDate(c.created_at, 'relative') %></p>
                    </div>
                    <div class="flex items-center gap-2">
                        <form method="POST" action="/admin/campsites/<%= c.id %>/approve"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button class="bg-forest-700 hover:bg-forest-600 text-forest-100 px-3 py-1.5 rounded-lg text-xs font-medium transition-colors">Approve</button>
                        </form>
                        <form method="POST" action="/admin/campsites/<%= c.id %>/reject"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button class="bg-red-900/50 hover:bg-red-900 text-red-400 px-3 py-1.5 rounded-lg text-xs font-medium transition-colors">Reject</button>
                        </form>
                    </div>
                </div>
                <% }) %>
            </div>
            <% } else { %>
            <p class="text-sm text-slate-500 bg-slate-800/30 border border-slate-700 rounded-lg p-4">No pending campsites.</p>
            <% } %>
        </div>

        <!-- Recent Users -->
        <div>
            <h2 class="text-lg font-display font-semibold text-slate-200 mb-4 flex items-center gap-2">
                <i data-lucide="users" class="w-5 h-5 text-forest-400"></i>
                Recent Users
            </h2>
            <div class="bg-slate-800/50 border border-slate-700 rounded-lg overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-slate-700 text-left text-xs text-slate-500 uppercase">
                            <th class="px-4 py-2">User</th>
                            <th class="px-4 py-2">Role</th>
                            <th class="px-4 py-2">Joined</th>
                            <th class="px-4 py-2">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-700">
                        <% recentUsers.forEach(user => { %>
                        <tr>
                            <td class="px-4 py-2">
                                <div>
                                    <span class="font-semibold text-slate-200"><%= user.display_name || user.username %></span>
                                    <span class="text-slate-500 text-xs ml-1">@<%= user.username %></span>
                                </div>
                            </td>
                            <td class="px-4 py-2">
                                <span class="text-xs px-2 py-0.5 rounded-full capitalize
                                    <%= user.role === 'admin' ? 'bg-amber-900/50 text-amber-400' : user.role === 'contributor' ? 'bg-forest-900/50 text-forest-400' : 'bg-slate-700 text-slate-400' %>">
                                    <%= user.role %>
                                </span>
                            </td>
                            <td class="px-4 py-2 text-xs text-slate-500"><%= helpers.formatDate(user.created_at, 'relative') %></td>
                            <td class="px-4 py-2">
                                <% if (user.id !== currentUser.id) { %>
                                <form method="POST" action="/admin/users/<%= user.id %>/role" class="flex items-center gap-1">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <select name="role" class="bg-slate-700 border border-slate-600 rounded text-xs text-slate-200 px-2 py-1">
                                        <option value="member" <%= user.role === 'member' ? 'selected' : '' %>>Member</option>
                                        <option value="contributor" <%= user.role === 'contributor' ? 'selected' : '' %>>Contributor</option>
                                        <option value="admin" <%= user.role === 'admin' ? 'selected' : '' %>>Admin</option>
                                    </select>
                                    <button class="bg-slate-600 hover:bg-slate-500 text-slate-200 px-2 py-1 rounded text-xs transition-colors">Set</button>
                                </form>
                                <% } %>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Recent Articles -->
        <div class="lg:col-span-2">
            <h2 class="text-lg font-display font-semibold text-slate-200 mb-4 flex items-center gap-2">
                <i data-lucide="book-open" class="w-5 h-5 text-amber-400"></i>
                Recent Articles
            </h2>
            <div class="bg-slate-800/50 border border-slate-700 rounded-lg overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-slate-700 text-left text-xs text-slate-500 uppercase">
                            <th class="px-4 py-2">Title</th>
                            <th class="px-4 py-2">Author</th>
                            <th class="px-4 py-2">Status</th>
                            <th class="px-4 py-2">Featured</th>
                            <th class="px-4 py-2">Views</th>
                            <th class="px-4 py-2">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-700">
                        <% recentArticles.forEach(a => { %>
                        <tr>
                            <td class="px-4 py-2">
                                <a href="/articles/<%= a.slug %>" class="text-slate-200 hover:text-amber-400 font-medium truncate block max-w-xs"><%= a.title %></a>
                            </td>
                            <td class="px-4 py-2 text-xs text-slate-500">@<%= a.username %></td>
                            <td class="px-4 py-2">
                                <span class="text-xs px-2 py-0.5 rounded-full capitalize
                                    <%= a.status === 'published' ? 'bg-forest-900/50 text-forest-400' : 'bg-slate-700 text-slate-400' %>">
                                    <%= a.status %>
                                </span>
                            </td>
                            <td class="px-4 py-2">
                                <% if (a.featured) { %>
                                <i data-lucide="star" class="w-4 h-4 text-amber-400 fill-amber-400"></i>
                                <% } %>
                            </td>
                            <td class="px-4 py-2 text-xs text-slate-500"><%= helpers.formatNumber(a.view_count) %></td>
                            <td class="px-4 py-2">
                                <form method="POST" action="/admin/articles/<%= a.id %>/feature" class="inline">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <button class="text-xs text-slate-400 hover:text-amber-400 transition-colors"><%= a.featured ? 'Unfeature' : 'Feature' %></button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<%- include('../layouts/end') %>
