<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.tailwindcss.com" rel="stylesheet">
</head>
<body class="bg-slate-50">
    <%- include('../shared/nav') %>
    
    <div class="min-h-screen bg-gradient-to-b from-slate-50 to-white">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <!-- Search Header -->
            <div class="mb-12">
                <h1 class="text-4xl font-bold text-slate-900 mb-4">Search</h1>
                
                <form method="GET" class="flex gap-2">
                    <input
                        type="text"
                        name="q"
                        value="<%= query %>"
                        placeholder="Search articles, forum posts, campsites..."
                        class="flex-1 px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                        minlength="2"
                    />
                    <button
                        type="submit"
                        class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium"
                    >
                        Search
                    </button>
                </form>
            </div>

            <% if (error) { %>
                <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded mb-8">
                    <%= error %>
                </div>
            <% } %>

            <% if (query && total === 0) { %>
                <div class="bg-blue-50 border border-blue-200 text-blue-700 px-4 py-3 rounded text-center">
                    No results found for "<%= query %>". Try different keywords.
                </div>
            <% } %>

            <% if (total > 0) { %>
                <div class="mb-4 text-slate-600 text-sm">
                    Found <strong><%= total %></strong> result<%= total !== 1 ? 's' : '' %> for "<%= query %>"
                </div>

                <!-- Articles Section -->
                <% if (articles.length > 0) { %>
                    <section class="mb-12">
                        <h2 class="text-2xl font-bold text-slate-900 mb-6 flex items-center gap-2">
                            <span class="text-2xl">📝</span> Articles (<%= articles.length %>)
                        </h2>
                        
                        <div class="space-y-4">
                            <% articles.forEach(article => { %>
                                <div class="bg-white border border-slate-200 rounded-lg p-6 hover:shadow-md transition">
                                    <h3 class="text-xl font-semibold text-slate-900 mb-2">
                                        <a href="/articles/<%= article.slug %>" class="text-blue-600 hover:underline">
                                            <%= article.title %>
                                        </a>
                                    </h3>
                                    <p class="text-slate-600 mb-3"><%= article.preview %></p>
                                    <div class="flex justify-between items-center text-sm text-slate-500">
                                        <a href="/users/<%= article.username %>" class="text-blue-600 hover:underline">
                                            <%= article.display_name %>
                                        </a>
                                        <span><%= new Date(article.created_at).toLocaleDateString() %></span>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    </section>
                <% } %>

                <!-- Forum Posts Section -->
                <% if (forum_posts.length > 0) { %>
                    <section class="mb-12">
                        <h2 class="text-2xl font-bold text-slate-900 mb-6 flex items-center gap-2">
                            <span class="text-2xl">💬</span> Forum Posts (<%= forum_posts.length %>)
                        </h2>
                        
                        <div class="space-y-4">
                            <% forum_posts.forEach(post => { %>
                                <div class="bg-white border border-slate-200 rounded-lg p-6 hover:shadow-md transition">
                                    <h3 class="text-xl font-semibold text-slate-900 mb-2">
                                        <a href="/forum/<%= post.slug %>" class="text-blue-600 hover:underline">
                                            <%= post.title %>
                                        </a>
                                    </h3>
                                    <p class="text-slate-600 mb-3"><%= post.preview %></p>
                                    <div class="flex justify-between items-center text-sm text-slate-500">
                                        <a href="/users/<%= post.username %>" class="text-blue-600 hover:underline">
                                            <%= post.display_name %>
                                        </a>
                                        <span><%= new Date(post.created_at).toLocaleDateString() %></span>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    </section>
                <% } %>

                <!-- Campsites Section -->
                <% if (campsites.length > 0) { %>
                    <section class="mb-12">
                        <h2 class="text-2xl font-bold text-slate-900 mb-6 flex items-center gap-2">
                            <span class="text-2xl">🏕️</span> Campsites (<%= campsites.length %>)
                        </h2>
                        
                        <div class="space-y-4">
                            <% campsites.forEach(campsite => { %>
                                <div class="bg-white border border-slate-200 rounded-lg p-6 hover:shadow-md transition">
                                    <h3 class="text-xl font-semibold text-slate-900 mb-2">
                                        <a href="/campsites/<%= campsite.id %>" class="text-blue-600 hover:underline">
                                            <%= campsite.name %>
                                        </a>
                                    </h3>
                                    <p class="text-slate-600 mb-3"><%= campsite.preview %></p>
                                    <div class="text-sm text-slate-500">
                                        <% if (campsite.country) { %>📍 <%= campsite.country %><% if (campsite.region) { %>, <%= campsite.region %><% } %><% } %>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    </section>
                <% } %>
            <% } %>
        </div>
    </div>

    <%- include('../shared/footer') %>
</body>
</html>
