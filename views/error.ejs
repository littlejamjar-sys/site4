<%- include('layouts/main') %>

<div class="max-w-2xl mx-auto px-4 py-24 text-center">
    <div class="text-8xl font-display font-bold text-slate-700 mb-4"><%= typeof status !== 'undefined' ? status : 500 %></div>
    <h1 class="text-2xl font-display font-bold text-slate-200 mb-4"><%= typeof title !== 'undefined' ? title : 'Something went wrong' %></h1>
    <p class="text-slate-400 mb-8"><%= typeof message !== 'undefined' ? message : 'An unexpected error occurred.' %></p>
    <a href="/" class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold px-6 py-3 rounded-lg transition-colors">
        <i data-lucide="home" class="w-4 h-4"></i> Back to Home
    </a>
</div>

<%- include('layouts/end') %>
