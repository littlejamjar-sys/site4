<%- include('../layouts/main') %>

<div class="max-w-4xl mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-slate-400 mb-6">
        <a href="/campsites" class="hover:text-amber-400">Spots</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <span class="text-slate-200 truncate"><%= campsite.name %></span>
    </div>

    <!-- Header -->
    <div class="bg-slate-800/50 border border-slate-700 rounded-xl overflow-hidden mb-6">
        <!-- Map -->
        <div id="campsite-detail-map" class="h-64 w-full"
             data-mode="single"
             data-lat="<%= campsite.latitude %>"
             data-lng="<%= campsite.longitude %>"
             data-name="<%= campsite.name %>"></div>

        <div class="p-6">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-4">
                <div>
                    <h1 class="text-2xl font-display font-bold text-slate-100 mb-1"><%= campsite.name %></h1>
                    <p class="text-slate-400 text-sm">
                        <% if (campsite.region) { %><%= campsite.region %>, <% } %><%= campsite.country || 'Unknown location' %>
                    </p>
                </div>
                <div class="flex items-center gap-2">
                    <span class="text-sm px-3 py-1 rounded-full bg-slate-700 text-slate-300 capitalize"><%= helpers.campsiteTypeLabel(campsite.type) %></span>
                    <% if (campsite.verified) { %>
                    <span class="text-sm px-3 py-1 rounded-full bg-forest-900/50 text-forest-400 flex items-center gap-1"><i data-lucide="badge-check" class="w-4 h-4"></i> Verified</span>
                    <% } %>
                </div>
            </div>

            <!-- Cost -->
            <div class="flex items-center gap-6 mb-4">
                <div class="text-lg font-semibold">
                    <% if (campsite.cost_per_night === null || campsite.cost_per_night === 0) { %>
                    <span class="text-forest-400">Free</span>
                    <% } else { %>
                    <span class="text-amber-400"><%= helpers.formatCurrency(campsite.cost_per_night, campsite.currency) %></span>
                    <span class="text-sm text-slate-500">/night</span>
                    <% } %>
                </div>
                <% if (campsite.rating_count > 0) { %>
                <div class="flex items-center gap-2">
                    <%- helpers.starRating(campsite.rating_avg) %>
                    <span class="text-sm text-slate-400">(<%= campsite.rating_count %> <%= campsite.rating_count === 1 ? 'review' : 'reviews' %>)</span>
                </div>
                <% } %>
            </div>

            <!-- Amenities -->
            <div class="flex flex-wrap gap-3 mb-4">
                <% const amenities = ['has_water', 'has_electric', 'has_toilet', 'has_shower', 'has_wifi', 'dog_friendly']; %>
                <% amenities.forEach(a => { %>
                <div class="flex items-center gap-1.5 text-sm <%= campsite[a] ? 'text-forest-400' : 'text-slate-600 line-through' %>">
                    <i data-lucide="<%= helpers.amenityIcon(a) %>" class="w-4 h-4"></i>
                    <span><%= helpers.amenityName(a) %></span>
                </div>
                <% }) %>
            </div>

            <% if (campsite.max_vehicle_length) { %>
            <p class="text-sm text-slate-400 mb-4"><i data-lucide="ruler" class="w-4 h-4 inline-block mr-1"></i> Max vehicle length: <%= campsite.max_vehicle_length %>m</p>
            <% } %>

            <% if (campsite.description) { %>
            <div class="mt-4 pt-4 border-t border-slate-700">
                <p class="text-slate-300 whitespace-pre-wrap"><%= campsite.description %></p>
            </div>
            <% } %>

            <!-- Submitted by -->
            <div class="flex items-center gap-2 mt-4 pt-4 border-t border-slate-700 text-sm text-slate-500">
                <span>Submitted by</span>
                <a href="/auth/user/<%= campsite.username %>" class="text-amber-400 hover:text-amber-300"><%= campsite.display_name || campsite.username %></a>
                <span>&middot;</span>
                <span><%= helpers.formatDate(campsite.created_at) %></span>
            </div>

            <!-- Coordinates for copying -->
            <div class="mt-3 text-xs text-slate-500">
                <span class="select-all cursor-pointer hover:text-slate-300" title="Click to select"><%= campsite.latitude.toFixed(5) %>, <%= campsite.longitude.toFixed(5) %></span>
            </div>
        </div>
    </div>

    <!-- Photos -->
    <% if (photos.length > 0) { %>
    <div class="mb-8">
        <h2 class="text-lg font-display font-semibold text-slate-200 mb-4">Photos</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            <% photos.forEach(photo => { %>
            <div class="aspect-video rounded-lg overflow-hidden bg-slate-800">
                <img src="<%= photo.file_path %>" alt="<%= photo.caption || campsite.name %>" class="w-full h-full object-cover" loading="lazy">
            </div>
            <% }) %>
        </div>
    </div>
    <% } %>

    <!-- Reviews -->
    <div id="reviews" class="mb-8">
        <h2 class="text-lg font-display font-semibold text-slate-200 mb-4">Reviews (<%= reviews.length %>)</h2>

        <% if (reviews.length > 0) { %>
        <div class="space-y-4 mb-6">
            <% reviews.forEach(review => { %>
            <div class="bg-slate-800/30 border border-slate-700 rounded-lg p-4">
                <div class="flex items-center justify-between mb-2">
                    <div class="flex items-center gap-2">
                        <a href="/auth/user/<%= review.username %>" class="flex items-center gap-2">
                            <% if (review.avatar_path) { %>
                            <img src="<%= review.avatar_path %>" alt="" class="w-6 h-6 rounded-full object-cover">
                            <% } else { %>
                            <div class="w-6 h-6 rounded-full bg-forest-700 flex items-center justify-center text-xs font-bold text-forest-100"><%= review.username.charAt(0).toUpperCase() %></div>
                            <% } %>
                            <span class="text-sm font-semibold text-slate-200"><%= review.display_name || review.username %></span>
                        </a>
                    </div>
                    <div class="flex items-center gap-2">
                        <%- helpers.starRating(review.rating) %>
                        <span class="text-xs text-slate-500"><%= helpers.formatDate(review.created_at, 'relative') %></span>
                    </div>
                </div>
                <% if (review.comment) { %>
                <p class="text-sm text-slate-300"><%= review.comment %></p>
                <% } %>
                <% if (review.visited_date) { %>
                <p class="text-xs text-slate-500 mt-2">Visited: <%= helpers.formatDate(review.visited_date, 'short') %></p>
                <% } %>
            </div>
            <% }) %>
        </div>
        <% } %>

        <!-- Review form -->
        <% if (isAuthenticated && !userReview) { %>
        <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-6">
            <h3 class="font-display font-semibold text-slate-200 mb-4">Leave a Review</h3>
            <form method="POST" action="/campsites/<%= campsite.id %>/review">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                <div class="mb-4">
                    <label class="block text-sm font-medium text-slate-300 mb-2">Rating</label>
                    <div class="flex gap-2">
                        <% for (let i = 1; i <= 5; i++) { %>
                        <label class="cursor-pointer">
                            <input type="radio" name="rating" value="<%= i %>" class="sr-only peer" required>
                            <i data-lucide="star" class="w-8 h-8 peer-checked:fill-amber-400 peer-checked:text-amber-400 text-slate-600 hover:text-amber-400 transition-colors"></i>
                        </label>
                        <% } %>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="block text-sm font-medium text-slate-300 mb-1">Comment</label>
                    <textarea name="comment" rows="3" placeholder="Tell others about your experience..."
                        class="w-full bg-slate-900 border border-slate-700 rounded-lg px-3 py-2 text-sm text-slate-100 placeholder-slate-500 focus:outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500"></textarea>
                </div>

                <div class="mb-4">
                    <label class="block text-sm font-medium text-slate-300 mb-1">Date Visited</label>
                    <input type="date" name="visited_date"
                        class="bg-slate-900 border border-slate-700 rounded-lg px-3 py-2 text-sm text-slate-100 focus:outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500">
                </div>

                <button type="submit" class="bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold px-5 py-2 rounded-lg transition-colors">Submit Review</button>
            </form>
        </div>
        <% } else if (isAuthenticated && userReview) { %>
        <p class="text-sm text-slate-500">You've already reviewed this spot.</p>
        <% } else { %>
        <p class="text-sm text-slate-500"><a href="/auth/login" class="text-amber-400 hover:text-amber-300">Log in</a> to leave a review.</p>
        <% } %>
    </div>

    <!-- Nearby -->
    <% if (nearby.length > 0) { %>
    <div>
        <h2 class="text-lg font-display font-semibold text-slate-200 mb-4">Nearby Spots</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <% nearby.forEach(campsite => { %>
                <%- include('../partials/campsite-card', { campsite }) %>
            <% }) %>
        </div>
    </div>
    <% } %>
</div>

<%- include('../layouts/end') %>
