<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.tailwindcss.com" rel="stylesheet">
</head>
<body class="bg-slate-50">
    <%- include('../shared/nav') %>
    
    <div class="min-h-screen bg-gradient-to-b from-slate-50 to-white">
        <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <h1 class="text-3xl font-bold text-slate-900 mb-8">Edit Your Profile</h1>

            <form id="editForm" class="bg-white border border-slate-200 rounded-lg p-8">
                <!-- Display Name -->
                <div class="mb-6">
                    <label for="display_name" class="block text-sm font-medium text-slate-700 mb-2">
                        Display Name *
                    </label>
                    <input
                        type="text"
                        id="display_name"
                        name="display_name"
                        value="<%= user.display_name || '' %>"
                        required
                        maxlength="100"
                        class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                    />
                    <p class="text-sm text-slate-500 mt-1">How others see your name</p>
                </div>

                <!-- Bio -->
                <div class="mb-6">
                    <label for="bio" class="block text-sm font-medium text-slate-700 mb-2">
                        Bio
                    </label>
                    <textarea
                        id="bio"
                        name="bio"
                        maxlength="500"
                        rows="4"
                        class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                    ><%= user.bio || '' %></textarea>
                    <p class="text-sm text-slate-500 mt-1">Tell others about yourself (max 500 chars)</p>
                </div>

                <!-- Location -->
                <div class="mb-6">
                    <label for="location" class="block text-sm font-medium text-slate-700 mb-2">
                        Location
                    </label>
                    <input
                        type="text"
                        id="location"
                        name="location"
                        value="<%= user.location || '' %>"
                        placeholder="e.g., Portugal"
                        class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                    />
                </div>

                <!-- Van Name -->
                <div class="mb-6">
                    <label for="van_name" class="block text-sm font-medium text-slate-700 mb-2">
                        Van Name
                    </label>
                    <input
                        type="text"
                        id="van_name"
                        name="van_name"
                        value="<%= user.van_name || '' %>"
                        placeholder="e.g., Rusty, Wanderer"
                        class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                    />
                </div>

                <!-- Van Type -->
                <div class="mb-8">
                    <label for="van_type" class="block text-sm font-medium text-slate-700 mb-2">
                        Van Type
                    </label>
                    <select
                        id="van_type"
                        name="van_type"
                        class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                    >
                        <option value="">Select a type</option>
                        <option value="Transit" <%= user.van_type === 'Transit' ? 'selected' : '' %>>Transit</option>
                        <option value="Sprinter" <%= user.van_type === 'Sprinter' ? 'selected' : '' %>>Sprinter</option>
                        <option value="Promaster" <%= user.van_type === 'Promaster' ? 'selected' : '' %>>Promaster</option>
                        <option value="Camper" <%= user.van_type === 'Camper' ? 'selected' : '' %>>Camper</option>
                        <option value="Motorhome" <%= user.van_type === 'Motorhome' ? 'selected' : '' %>>Motorhome</option>
                        <option value="Other" <%= user.van_type === 'Other' ? 'selected' : '' %>>Other</option>
                    </select>
                </div>

                <!-- Error/Success Messages -->
                <div id="message" class="mb-6 p-4 rounded-lg hidden"></div>

                <!-- Buttons -->
                <div class="flex gap-4">
                    <button
                        type="submit"
                        class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium"
                    >
                        Save Changes
                    </button>
                    <a
                        href="/users/<%= user.username %>"
                        class="px-6 py-2 border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-50 transition"
                    >
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>

    <%- include('../shared/footer') %>

    <script>
        const form = document.getElementById('editForm');
        const messageDiv = document.getElementById('message');

        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const formData = new FormData(form);
            const data = Object.fromEntries(formData);

            try {
                const response = await fetch(window.location.href, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                messageDiv.classList.remove('hidden', 'bg-red-50', 'text-red-700', 'border', 'border-red-200');
                messageDiv.classList.add(response.ok ? 'bg-green-50 text-green-700 border border-green-200' : 'bg-red-50 text-red-700 border border-red-200');
                messageDiv.textContent = result.message || result.error || 'An error occurred';

                if (response.ok) {
                    setTimeout(() => {
                        window.location.href = result.redirect;
                    }, 1000);
                }
            } catch (error) {
                messageDiv.classList.remove('hidden');
                messageDiv.classList.add('bg-red-50', 'text-red-700', 'border', 'border-red-200');
                messageDiv.textContent = 'Failed to update profile';
            }
        });
    </script>
</body>
</html>
