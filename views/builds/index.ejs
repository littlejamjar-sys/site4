<%- include('../layouts/main') %>

<div class="max-w-7xl mx-auto px-4 py-8">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
        <div>
            <h1 class="text-3xl font-display font-bold text-slate-100"><%= title %></h1>
            <p class="text-slate-400 mt-1">Document your van conversion journey</p>
        </div>
        <% if (isAuthenticated) { %>
        <a href="/builds/new" class="bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold px-5 py-2.5 rounded-lg transition-colors flex items-center gap-2">
            <i data-lucide="plus" class="w-4 h-4"></i> Start a Build
        </a>
        <% } %>
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap gap-2 mb-8">
        <a href="/builds" class="px-3 py-1.5 rounded-lg text-sm font-medium transition-colors <%= !currentStatus && !showingMine ? 'bg-amber-500 text-slate-900' : 'bg-slate-800 border border-slate-700 text-slate-300 hover:text-white hover:bg-slate-700' %>">All</a>
        <% statuses.forEach(s => { %>
        <a href="/builds?status=<%= s %>" class="px-3 py-1.5 rounded-lg text-sm font-medium transition-colors capitalize <%= currentStatus === s ? 'bg-amber-500 text-slate-900' : 'bg-slate-800 border border-slate-700 text-slate-300 hover:text-white hover:bg-slate-700' %>"><%= s.replace('-', ' ') %></a>
        <% }) %>
        <% if (isAuthenticated) { %>
        <a href="/builds?mine=1" class="px-3 py-1.5 rounded-lg text-sm font-medium transition-colors ml-2 <%= showingMine ? 'bg-forest-700 text-forest-100' : 'bg-slate-800 border border-slate-700 text-slate-300 hover:text-white hover:bg-slate-700' %>"><i data-lucide="user" class="w-3.5 h-3.5 inline-block mr-1"></i>My Builds</a>
        <% } %>
    </div>

    <!-- Results -->
    <p class="text-sm text-slate-500 mb-4"><%= helpers.formatNumber(pagination.totalItems) %> builds</p>

    <% if (builds.length > 0) { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% builds.forEach(build => { %>
            <%- include('../partials/build-card', { build }) %>
        <% }) %>
    </div>

    <%- include('../partials/pagination') %>
    <% } else { %>
    <div class="text-center py-16">
        <i data-lucide="wrench" class="w-16 h-16 text-slate-700 mx-auto mb-4"></i>
        <h2 class="text-xl font-display font-semibold text-slate-400 mb-2">No builds yet</h2>
        <p class="text-slate-500">Start documenting your conversion with a <a href="/builds/new" class="text-amber-400 hover:text-amber-300">build log</a>.</p>
    </div>
    <% } %>
</div>

<%- include('../layouts/end') %>
