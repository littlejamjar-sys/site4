<%- include('../layouts/main') %>

<div class="max-w-4xl mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-slate-400 mb-6">
        <a href="/routes" class="hover:text-amber-400">Routes</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <span class="text-slate-200 truncate"><%= route.title %></span>
    </div>

    <!-- Cover image -->
    <% if (route.cover_image) { %>
    <div class="aspect-[21/9] rounded-xl overflow-hidden mb-6 bg-slate-800">
        <img src="<%= route.cover_image %>" alt="<%= route.title %>" class="w-full h-full object-cover">
    </div>
    <% } %>

    <!-- Title & meta -->
    <div class="mb-6">
        <h1 class="text-3xl font-display font-bold text-slate-100 mb-3"><%= route.title %></h1>
        <div class="flex flex-wrap items-center gap-3">
            <% if (route.country) { %>
            <span class="px-3 py-1 rounded-full bg-slate-700 text-sm text-slate-300"><%= route.country %><% if (route.region) { %> &middot; <%= route.region %><% } %></span>
            <% } %>
            <% if (route.difficulty) { %>
            <span class="px-3 py-1 rounded-full text-sm capitalize <%= helpers.difficultyColor(route.difficulty) %>"><%= route.difficulty %></span>
            <% } %>
            <% if (route.rating_count > 0) { %>
            <div class="flex items-center gap-1">
                <%- helpers.starRating(route.rating_avg) %>
                <span class="text-sm text-slate-400 ml-1">(<%= route.rating_count %>)</span>
            </div>
            <% } %>
        </div>
    </div>

    <!-- Stats bar -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
        <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-4 text-center">
            <p class="text-xs text-slate-500 uppercase tracking-wider mb-1">Distance</p>
            <p class="text-xl font-display font-bold text-slate-100"><%= route.distance_km ? helpers.formatNumber(Math.round(route.distance_km)) + ' km' : '—' %></p>
        </div>
        <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-4 text-center">
            <p class="text-xs text-slate-500 uppercase tracking-wider mb-1">Duration</p>
            <p class="text-xl font-display font-bold text-slate-100"><%= route.duration_days ? helpers.pluralize(route.duration_days, 'day') : '—' %></p>
        </div>
        <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-4 text-center">
            <p class="text-xs text-slate-500 uppercase tracking-wider mb-1">Best Season</p>
            <p class="text-xl font-display font-bold text-slate-100"><%= route.best_season || '—' %></p>
        </div>
        <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-4 text-center">
            <p class="text-xs text-slate-500 uppercase tracking-wider mb-1">Views</p>
            <p class="text-xl font-display font-bold text-slate-100"><%= helpers.formatNumber(route.view_count) %></p>
        </div>
    </div>

    <!-- Map -->
    <% if (waypointsData.length > 0) { %>
    <div class="bg-slate-800/50 border border-slate-700 rounded-xl overflow-hidden mb-8">
        <div id="route-map" class="h-96 w-full" data-mode="route" data-slug="<%= route.slug %>"
             data-waypoints='<%= JSON.stringify(waypointsData) %>'></div>
    </div>
    <% } %>

    <!-- Export GPX -->
    <div class="flex gap-3 mb-8">
        <a href="/routes/<%= route.slug %>/gpx" class="bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-300 hover:text-white font-medium px-4 py-2 rounded-lg text-sm transition-colors flex items-center gap-2">
            <i data-lucide="download" class="w-4 h-4"></i> Download GPX
        </a>
    </div>

    <!-- Author -->
    <div class="flex items-center gap-3 mb-6 pb-6 border-b border-slate-700">
        <a href="/auth/user/<%= route.username %>">
            <% if (route.avatar_path) { %>
            <img src="<%= route.avatar_path %>" alt="" class="w-10 h-10 rounded-full object-cover">
            <% } else { %>
            <div class="w-10 h-10 rounded-full bg-forest-700 flex items-center justify-center text-sm font-bold text-forest-100"><%= route.username.charAt(0).toUpperCase() %></div>
            <% } %>
        </a>
        <div>
            <a href="/auth/user/<%= route.username %>" class="text-sm font-semibold text-slate-200 hover:text-amber-400"><%= route.display_name || route.username %></a>
            <p class="text-xs text-slate-500">Posted <%= helpers.formatDate(route.created_at) %></p>
        </div>
    </div>

    <!-- Description -->
    <div class="prose prose-invert prose-amber prose-lg max-w-none prose-p:text-slate-300 prose-a:text-amber-400 prose-headings:font-display mb-8">
        <%- route.descriptionHtml %>
    </div>

    <!-- Tags -->
    <% if (route.tags) { %>
    <div class="flex flex-wrap gap-2 mb-8 pb-8 border-b border-slate-700">
        <% route.tags.split(',').forEach(tag => { %>
        <span class="px-3 py-1 rounded-full bg-slate-800 border border-slate-700 text-xs text-slate-400">#<%= tag.trim() %></span>
        <% }) %>
    </div>
    <% } %>

    <!-- Reviews -->
    <div id="reviews" class="mb-8">
        <h2 class="text-lg font-display font-semibold text-slate-200 mb-4">Reviews (<%= reviews.length %>)</h2>

        <% if (reviews.length > 0) { %>
        <div class="space-y-4 mb-6">
            <% reviews.forEach(review => { %>
            <div class="bg-slate-800/30 border border-slate-700 rounded-lg p-4">
                <div class="flex items-center justify-between mb-2">
                    <div class="flex items-center gap-2">
                        <a href="/auth/user/<%= review.username %>" class="flex items-center gap-2">
                            <% if (review.avatar_path) { %>
                            <img src="<%= review.avatar_path %>" alt="" class="w-6 h-6 rounded-full object-cover">
                            <% } else { %>
                            <div class="w-6 h-6 rounded-full bg-forest-700 flex items-center justify-center text-xs font-bold text-forest-100"><%= review.username.charAt(0).toUpperCase() %></div>
                            <% } %>
                            <span class="text-sm font-semibold text-slate-200"><%= review.display_name || review.username %></span>
                        </a>
                    </div>
                    <div class="flex items-center gap-2">
                        <%- helpers.starRating(review.rating) %>
                        <span class="text-xs text-slate-500"><%= helpers.formatDate(review.created_at, 'relative') %></span>
                    </div>
                </div>
                <% if (review.comment) { %>
                <p class="text-sm text-slate-300"><%= review.comment %></p>
                <% } %>
                <% if (review.travelled_date) { %>
                <p class="text-xs text-slate-500 mt-2">Travelled: <%= helpers.formatDate(review.travelled_date, 'short') %></p>
                <% } %>
            </div>
            <% }) %>
        </div>
        <% } %>

        <!-- Review form -->
        <% if (isAuthenticated && !userReview) { %>
        <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-6">
            <h3 class="font-display font-semibold text-slate-200 mb-4">Rate this Route</h3>
            <form method="POST" action="/routes/<%= route.slug %>/review">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                <div class="mb-4">
                    <label class="block text-sm font-medium text-slate-300 mb-2">Rating</label>
                    <div class="flex gap-2">
                        <% for (let i = 1; i <= 5; i++) { %>
                        <label class="cursor-pointer">
                            <input type="radio" name="rating" value="<%= i %>" class="sr-only peer" required>
                            <i data-lucide="star" class="w-8 h-8 peer-checked:fill-amber-400 peer-checked:text-amber-400 text-slate-600 hover:text-amber-400 transition-colors"></i>
                        </label>
                        <% } %>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="block text-sm font-medium text-slate-300 mb-1">Comment</label>
                    <textarea name="comment" rows="3" placeholder="Share your experience..."
                        class="w-full bg-slate-900 border border-slate-700 rounded-lg px-3 py-2 text-sm text-slate-100 placeholder-slate-500 focus:outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500"></textarea>
                </div>

                <div class="mb-4">
                    <label class="block text-sm font-medium text-slate-300 mb-1">Date Travelled</label>
                    <input type="date" name="travelled_date"
                        class="bg-slate-900 border border-slate-700 rounded-lg px-3 py-2 text-sm text-slate-100 focus:outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500">
                </div>

                <button type="submit" class="bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold px-5 py-2 rounded-lg transition-colors">Submit Review</button>
            </form>
        </div>
        <% } else if (isAuthenticated && userReview) { %>
        <p class="text-sm text-slate-500">You've already reviewed this route.</p>
        <% } else { %>
        <p class="text-sm text-slate-500"><a href="/auth/login" class="text-amber-400 hover:text-amber-300">Log in</a> to leave a review.</p>
        <% } %>
    </div>
</div>

<%- include('../layouts/end') %>
