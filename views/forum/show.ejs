<%- include('../layouts/main') %>

<div class="max-w-4xl mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-slate-400 mb-6">
        <a href="/forum" class="hover:text-amber-400">Forum</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <a href="/forum/<%= category.slug %>" class="hover:text-amber-400"><%= category.name %></a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <span class="text-slate-200 truncate max-w-xs"><%= post.title %></span>
    </div>

    <!-- Post -->
    <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-6 mb-8">
        <div class="flex items-start gap-4">
            <!-- Vote buttons -->
            <div class="flex flex-col items-center gap-1 flex-shrink-0" id="vote-post-<%= post.id %>">
                <button onclick="vote('post', <%= post.id %>, 1)" class="p-1 rounded hover:bg-slate-700 transition-colors <%= (typeof userVotes !== 'undefined' && userVotes['post_' + post.id] === 1) ? 'text-amber-400' : 'text-slate-500 hover:text-white' %>">
                    <i data-lucide="chevron-up" class="w-5 h-5"></i>
                </button>
                <span class="text-sm font-semibold vote-score <%= post.vote_score > 0 ? 'text-forest-400' : post.vote_score < 0 ? 'text-red-400' : 'text-slate-400' %>"><%= post.vote_score %></span>
                <button onclick="vote('post', <%= post.id %>, -1)" class="p-1 rounded hover:bg-slate-700 transition-colors <%= (typeof userVotes !== 'undefined' && userVotes['post_' + post.id] === -1) ? 'text-red-400' : 'text-slate-500 hover:text-white' %>">
                    <i data-lucide="chevron-down" class="w-5 h-5"></i>
                </button>
            </div>

            <div class="flex-1 min-w-0">
                <!-- Title & badges -->
                <div class="flex flex-wrap items-center gap-2 mb-3">
                    <% if (post.pinned) { %>
                    <span class="text-xs px-2 py-0.5 rounded-full bg-amber-900/50 text-amber-400 font-medium">Pinned</span>
                    <% } %>
                    <% if (post.locked) { %>
                    <span class="text-xs px-2 py-0.5 rounded-full bg-slate-700 text-slate-400 flex items-center gap-1"><i data-lucide="lock" class="w-3 h-3"></i> Locked</span>
                    <% } %>
                </div>
                <h1 class="text-2xl font-display font-bold text-slate-100 mb-4"><%= post.title %></h1>

                <!-- Author info -->
                <div class="flex items-center gap-3 mb-4">
                    <a href="/auth/user/<%= post.username %>">
                        <% if (post.avatar_path) { %>
                        <img src="<%= post.avatar_path %>" alt="" class="w-8 h-8 rounded-full object-cover">
                        <% } else { %>
                        <div class="w-8 h-8 rounded-full bg-forest-700 flex items-center justify-center text-sm font-bold text-forest-100"><%= post.username.charAt(0).toUpperCase() %></div>
                        <% } %>
                    </a>
                    <div>
                        <a href="/auth/user/<%= post.username %>" class="text-sm font-semibold text-slate-200 hover:text-amber-400"><%= post.display_name || post.username %></a>
                        <div class="flex items-center gap-2 text-xs text-slate-500">
                            <span class="capitalize"><%= post.author_role %></span>
                            <span>&middot;</span>
                            <span><%= post.reputation %> rep</span>
                            <span>&middot;</span>
                            <span><%= helpers.formatDate(post.created_at, 'relative') %></span>
                        </div>
                    </div>
                </div>

                <!-- Content -->
                <div class="prose prose-invert prose-amber prose-sm max-w-none prose-p:text-slate-300 prose-a:text-amber-400 prose-code:text-amber-300 prose-code:bg-slate-800">
                    <%- post.contentHtml %>
                </div>

                <!-- Post meta -->
                <div class="flex items-center gap-4 mt-4 pt-4 border-t border-slate-700 text-xs text-slate-500">
                    <span class="flex items-center gap-1"><i data-lucide="eye" class="w-3.5 h-3.5"></i> <%= helpers.formatNumber(post.view_count) %> views</span>
                    <span class="flex items-center gap-1"><i data-lucide="message-square" class="w-3.5 h-3.5"></i> <%= post.reply_count %> replies</span>
                    <% if (isAuthenticated && currentUser.role === 'admin') { %>
                    <form method="POST" action="/forum/<%= category.slug %>/<%= post.slug %>/pin" class="inline"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="hover:text-amber-400"><%= post.pinned ? 'Unpin' : 'Pin' %></button></form>
                    <form method="POST" action="/forum/<%= category.slug %>/<%= post.slug %>/lock" class="inline"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="hover:text-amber-400"><%= post.locked ? 'Unlock' : 'Lock' %></button></form>
                    <form method="POST" action="/forum/<%= category.slug %>/<%= post.slug %>/delete" class="inline" onsubmit="return confirm('Delete this post and all replies?')"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="hover:text-red-400">Delete</button></form>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Replies -->
    <div id="replies">
        <h2 class="text-lg font-display font-semibold text-slate-200 mb-4"><%= helpers.pluralize(post.reply_count, 'Reply', 'Replies') %></h2>

        <% if (replies.length > 0) { %>
        <div class="space-y-4">
            <% replies.forEach(reply => { %>
            <div class="bg-slate-800/30 border border-slate-700 rounded-lg p-4" id="reply-<%= reply.id %>">
                <div class="flex items-start gap-3">
                    <!-- Vote -->
                    <div class="flex flex-col items-center gap-0.5 flex-shrink-0" id="vote-reply-<%= reply.id %>">
                        <button onclick="vote('reply', <%= reply.id %>, 1)" class="p-0.5 rounded hover:bg-slate-700 <%= (typeof userVotes !== 'undefined' && userVotes['reply_' + reply.id] === 1) ? 'text-amber-400' : 'text-slate-500 hover:text-white' %>">
                            <i data-lucide="chevron-up" class="w-4 h-4"></i>
                        </button>
                        <span class="text-xs font-semibold vote-score <%= reply.vote_score > 0 ? 'text-forest-400' : reply.vote_score < 0 ? 'text-red-400' : 'text-slate-500' %>"><%= reply.vote_score %></span>
                        <button onclick="vote('reply', <%= reply.id %>, -1)" class="p-0.5 rounded hover:bg-slate-700 <%= (typeof userVotes !== 'undefined' && userVotes['reply_' + reply.id] === -1) ? 'text-red-400' : 'text-slate-500 hover:text-white' %>">
                            <i data-lucide="chevron-down" class="w-4 h-4"></i>
                        </button>
                    </div>

                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 mb-2">
                            <a href="/auth/user/<%= reply.username %>" class="flex items-center gap-2">
                                <% if (reply.avatar_path) { %>
                                <img src="<%= reply.avatar_path %>" alt="" class="w-6 h-6 rounded-full object-cover">
                                <% } else { %>
                                <div class="w-6 h-6 rounded-full bg-forest-700 flex items-center justify-center text-xs font-bold text-forest-100"><%= reply.username.charAt(0).toUpperCase() %></div>
                                <% } %>
                                <span class="text-sm font-semibold text-slate-200 hover:text-amber-400"><%= reply.display_name || reply.username %></span>
                            </a>
                            <span class="text-xs text-slate-500"><%= helpers.formatDate(reply.created_at, 'relative') %></span>
                        </div>

                        <div class="prose prose-invert prose-amber prose-sm max-w-none prose-p:text-slate-300">
                            <%- reply.contentHtml %>
                        </div>

                        <% if (!post.locked || (isAuthenticated && currentUser.role === 'admin')) { %>
                        <button onclick="showReplyForm(<%= reply.id %>)" class="text-xs text-slate-500 hover:text-amber-400 mt-2 flex items-center gap-1">
                            <i data-lucide="reply" class="w-3 h-3"></i> Reply
                        </button>
                        <% } %>

                        <!-- Threaded reply form (hidden by default) -->
                        <div id="reply-form-<%= reply.id %>" class="hidden mt-3">
                            <form method="POST" action="/forum/<%= category.slug %>/<%= post.slug %>/reply">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <input type="hidden" name="parent_reply_id" value="<%= reply.id %>">
                                <textarea name="content" rows="3" required placeholder="Write a reply..."
                                    class="w-full bg-slate-900 border border-slate-700 rounded-lg px-3 py-2 text-sm text-slate-100 placeholder-slate-500 focus:outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500 mb-2"></textarea>
                                <button type="submit" class="bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold px-3 py-1.5 rounded-lg text-sm transition-colors">Reply</button>
                            </form>
                        </div>

                        <!-- Child replies -->
                        <% if (reply.children && reply.children.length > 0) { %>
                        <div class="mt-4 space-y-3 pl-4 border-l-2 border-slate-700">
                            <% reply.children.forEach(child => { %>
                            <div class="bg-slate-800/20 rounded-lg p-3" id="reply-<%= child.id %>">
                                <div class="flex items-start gap-2">
                                    <div class="flex flex-col items-center gap-0.5 flex-shrink-0" id="vote-reply-<%= child.id %>">
                                        <button onclick="vote('reply', <%= child.id %>, 1)" class="p-0.5 rounded hover:bg-slate-700 <%= (typeof userVotes !== 'undefined' && userVotes['reply_' + child.id] === 1) ? 'text-amber-400' : 'text-slate-500 hover:text-white' %>"><i data-lucide="chevron-up" class="w-3 h-3"></i></button>
                                        <span class="text-xs vote-score <%= child.vote_score > 0 ? 'text-forest-400' : child.vote_score < 0 ? 'text-red-400' : 'text-slate-500' %>"><%= child.vote_score %></span>
                                        <button onclick="vote('reply', <%= child.id %>, -1)" class="p-0.5 rounded hover:bg-slate-700 <%= (typeof userVotes !== 'undefined' && userVotes['reply_' + child.id] === -1) ? 'text-red-400' : 'text-slate-500 hover:text-white' %>"><i data-lucide="chevron-down" class="w-3 h-3"></i></button>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <div class="flex items-center gap-2 mb-1">
                                            <a href="/auth/user/<%= child.username %>" class="text-xs font-semibold text-slate-300 hover:text-amber-400"><%= child.display_name || child.username %></a>
                                            <span class="text-xs text-slate-600"><%= helpers.formatDate(child.created_at, 'relative') %></span>
                                        </div>
                                        <div class="prose prose-invert prose-amber prose-xs max-w-none prose-p:text-slate-400">
                                            <%- child.contentHtml %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>
        <% } %>

        <!-- Reply Form -->
        <% if (isAuthenticated && (!post.locked || currentUser.role === 'admin')) { %>
        <div class="mt-8 bg-slate-800/50 border border-slate-700 rounded-xl p-6">
            <h3 class="font-display font-semibold text-slate-200 mb-4">Leave a Reply</h3>
            <form method="POST" action="/forum/<%= category.slug %>/<%= post.slug %>/reply">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <textarea name="content" rows="5" required placeholder="Write your reply... (Markdown supported)"
                    class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-3 text-slate-100 placeholder-slate-500 focus:outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500 mb-3"></textarea>
                <button type="submit" class="bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold px-6 py-2.5 rounded-lg transition-colors">Post Reply</button>
            </form>
        </div>
        <% } else if (!isAuthenticated) { %>
        <div class="mt-8 text-center py-8 bg-slate-800/30 border border-slate-700 rounded-xl">
            <p class="text-slate-400"><a href="/auth/login" class="text-amber-400 hover:text-amber-300">Log in</a> to reply to this discussion.</p>
        </div>
        <% } else if (post.locked) { %>
        <div class="mt-8 text-center py-8 bg-slate-800/30 border border-slate-700 rounded-xl">
            <p class="text-slate-400 flex items-center justify-center gap-2"><i data-lucide="lock" class="w-4 h-4"></i> This discussion is locked.</p>
        </div>
        <% } %>
    </div>
</div>

<script>
function showReplyForm(id) {
    const form = document.getElementById('reply-form-' + id);
    if (form) form.classList.toggle('hidden');
}
</script>

<%- include('../layouts/end') %>
