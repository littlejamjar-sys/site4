<%- include('../layouts/main') %>

<div class="max-w-4xl mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-slate-400 mb-6">
        <a href="/forum" class="hover:text-amber-400">Forum</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <span class="text-slate-200"><%= category.name %></span>
    </div>

    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-6 gap-4">
        <div>
            <h1 class="text-2xl font-display font-bold text-slate-100 flex items-center gap-2">
                <i data-lucide="<%= category.icon %>" class="w-6 h-6 text-forest-400"></i> <%= category.name %>
            </h1>
            <p class="text-sm text-slate-400 mt-1"><%= category.description %></p>
        </div>
        <% if (isAuthenticated) { %>
        <a href="/forum/new?category=<%= category.slug %>" class="bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold px-4 py-2 rounded-lg transition-colors flex items-center gap-2 text-sm">
            <i data-lucide="plus" class="w-4 h-4"></i> New Post
        </a>
        <% } %>
    </div>

    <!-- Sort tabs -->
    <div class="flex items-center gap-1 mb-6 border-b border-slate-700">
        <a href="/forum/<%= category.slug %>?sort=newest" class="px-4 py-2 text-sm font-medium border-b-2 -mb-px transition-colors <%= sort === 'newest' ? 'border-amber-400 text-amber-400' : 'border-transparent text-slate-400 hover:text-white' %>">Newest</a>
        <a href="/forum/<%= category.slug %>?sort=active" class="px-4 py-2 text-sm font-medium border-b-2 -mb-px transition-colors <%= sort === 'active' ? 'border-amber-400 text-amber-400' : 'border-transparent text-slate-400 hover:text-white' %>">Most Active</a>
        <a href="/forum/<%= category.slug %>?sort=popular" class="px-4 py-2 text-sm font-medium border-b-2 -mb-px transition-colors <%= sort === 'popular' ? 'border-amber-400 text-amber-400' : 'border-transparent text-slate-400 hover:text-white' %>">Most Popular</a>
    </div>

    <% if (posts.length > 0) { %>
    <div class="space-y-2">
        <% posts.forEach(post => { %>
        <a href="/forum/<%= category.slug %>/<%= post.slug %>" class="block bg-slate-800/50 border border-slate-700 rounded-lg p-4 hover:border-slate-600 transition-colors group">
            <div class="flex items-start gap-3">
                <!-- Vote score -->
                <div class="text-center flex-shrink-0 w-10">
                    <p class="text-sm font-semibold <%= post.vote_score > 0 ? 'text-forest-400' : post.vote_score < 0 ? 'text-red-400' : 'text-slate-500' %>"><%= post.vote_score %></p>
                    <p class="text-xs text-slate-600">votes</p>
                </div>

                <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1">
                        <% if (post.pinned) { %>
                        <span class="text-xs px-1.5 py-0.5 rounded bg-amber-900/50 text-amber-400 font-medium">Pinned</span>
                        <% } %>
                        <% if (post.locked) { %>
                        <span class="text-xs px-1.5 py-0.5 rounded bg-slate-700 text-slate-400"><i data-lucide="lock" class="w-3 h-3 inline-block"></i></span>
                        <% } %>
                    </div>
                    <h3 class="font-semibold text-slate-200 group-hover:text-amber-400 transition-colors line-clamp-1"><%= post.title %></h3>
                    <div class="flex flex-wrap items-center gap-3 mt-2 text-xs text-slate-500">
                        <span class="flex items-center gap-1">
                            <% if (post.avatar_path) { %>
                            <img src="<%= post.avatar_path %>" alt="" class="w-4 h-4 rounded-full object-cover">
                            <% } %>
                            <%= post.display_name || post.username %>
                        </span>
                        <span><%= helpers.formatDate(post.created_at, 'relative') %></span>
                        <span class="flex items-center gap-1"><i data-lucide="message-square" class="w-3.5 h-3.5"></i> <%= post.reply_count %></span>
                        <span class="flex items-center gap-1"><i data-lucide="eye" class="w-3.5 h-3.5"></i> <%= helpers.formatNumber(post.view_count) %></span>
                    </div>
                </div>
            </div>
        </a>
        <% }) %>
    </div>
    <%- include('../partials/pagination') %>
    <% } else { %>
    <div class="text-center py-16">
        <i data-lucide="message-square" class="w-12 h-12 text-slate-600 mx-auto mb-4"></i>
        <p class="text-lg text-slate-400">No posts in this category yet.</p>
        <% if (isAuthenticated) { %>
        <a href="/forum/new?category=<%= category.slug %>" class="inline-block mt-4 bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold px-4 py-2 rounded-lg transition-colors">Start a discussion</a>
        <% } %>
    </div>
    <% } %>
</div>

<%- include('../layouts/end') %>
